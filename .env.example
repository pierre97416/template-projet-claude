# FusionSolar Northbound API
FUSIONSOLAR_BASE_URL=https://eu5.fusionsolar.huawei.com
FUSIONSOLAR_USERNAME=USERNAME
FUSIONSOLAR_SYSTEMCODE=PASS

# InfluxDB
# Avec Docker : INFLUX_URL=http://localhost:8086 (le collector utilise http://influxdb:8086 en interne)
# INFLUX_TOKEN doit correspondre à DOCKER_INFLUXDB_INIT_ADMIN_TOKEN dans docker-compose.yml
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your_influx_token
INFLUX_ORG=pv
INFLUX_BUCKET=fusionsolar

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Comportement du collector
# MOCK_MODE=true pour bypasser FusionSolar et générer des données fictives (test pipeline)
MOCK_MODE=false
POLL_SECONDS=60
ALERT_COOLDOWN_SECONDS=1800
DAILY_SUMMARY_HOUR=19
DAILY_SUMMARY_MINUTE=30
